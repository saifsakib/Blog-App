# =====================================================================
# Backend / DB env file.
# Copy this to `.env` (which is gitignored) and fill in real values
# for local development. In CI/CD this file is generated on the
# remote hosts from GitHub Secrets — see DEPLOYMENT.md.
# =====================================================================

# ─────────── Express server ───────────
PORT=5000
TOKEN_SECRET=change-me-long-random
COOKIE_SECRET=change-me-long-random

# ─────────── Postgres connection ──────
# Locally: DB_HOST=localhost
# In Docker compose locally: DB_HOST=db (the service name)
# In production: DB_HOST = private DNS/IP of the db host
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blogApp
DB_USER=postgres
DB_PASSWORD=change-me

# ─────────── GHCR image pinning ───────
# Only needed on the remote backend host. The deploy workflow writes
# these automatically; you don't need them for local dev.
# GITHUB_REPOSITORY=owner/repo
# IMAGE_TAG=latest
