# =====================================================================
# Frontend (Next.js + NextAuth) env file.
# Copy this to `.env.local` (gitignored) and fill in values for local
# dev. In CI/CD it's generated on the frontend host from GitHub
# Secrets — see DEPLOYMENT.md.
# =====================================================================

# Public URL the browser uses to reach the frontend.
# Locally:    http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Long random string used to sign the NextAuth JWT cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=change-me-long-random

# URL the frontend (server-side) uses to reach the backend.
# Locally:                 http://localhost:5000
# Local docker compose:    http://backend:5000   (docker service name)
# Production:              http://<backend-private-ip>:5000
BLOG_API_URL=http://localhost:5000

# ─────────── GHCR image pinning ───────
# Only needed on the remote frontend host. The deploy workflow writes
# these automatically; you don't need them for local dev.
# GITHUB_REPOSITORY=owner/repo
# IMAGE_TAG=latest
