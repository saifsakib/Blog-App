{
  "name": "blog-app",
  "version": "1.0.0",
  "private": true,
  "description": "Single package.json managing the Express backend (./) and the Next.js frontend (./frontend).",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm run start:backend\" \"npm run dev:frontend\"",

    "start:backend": "nodemon --legacy-watch server.js",
    "seed": "node seeder.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "migration:generate": "sequelize-cli migration:generate --name",

    "dev:frontend": "next dev frontend -p 3000",
    "build:frontend": "next build frontend",
    "start:frontend": "next start frontend -p 3000"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.5"
  },
  "dependencies": {
    "async": "^3.2.4",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "glob": "^10.3.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "next": "^14.2.5",
    "next-auth": "^4.24.7",
    "node-cache": "^5.1.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sequelize": "^6.33.0"
  }
}
